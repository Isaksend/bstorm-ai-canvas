# --- База и вход (регистрация / сессия) ---
# Локальный PostgreSQL + pgAdmin 4:
# 1) Установите PostgreSQL с https://www.postgresql.org/download/windows/ (в комплекте часто идёт pgAdmin 4).
# 2) Запомните пароль пользователя postgres.
# 3) В pgAdmin: подключитесь к серверу → Databases → Create → Database → имя, например ai_brainstorm
# 4) Скопируйте этот файл в .env и .env.local, подставьте пароль (спецсимволы в пароле — encodeURIComponent).
# 5) npx prisma db push
DATABASE_URL="postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5432/ai_brainstorm?schema=public"
# Тот же URI, что DATABASE_URL (обязательно для Prisma при локальном Postgres без pooler).
DATABASE_URL_UNPOOLED="postgresql://postgres:ВАШ_ПАРОЛЬ@localhost:5432/ai_brainstorm?schema=public"
#
# Neon через Vercel Storage: в панели Neon есть DATABASE_URL (pooled) и DATABASE_URL_UNPOOLED —
# скопируйте обе в Vercel → Environment Variables и при необходимости в .env для prisma db push.
# Обязательно для входа/сессии (без этого — ClientFetchError configuration). Сгенерировать:
#   openssl rand -base64 32
# В dev при пустом значении подставится временный ключ (см. предупреждение в консоли сервера).
AUTH_SECRET=
# Локально: http://localhost:3000  Продакшен: https://ваш-домен.vercel.app
AUTH_URL=http://localhost:3000

# Режим 1 — быстрый старт (без имён в UI): публичный ключ из Liveblocks Dashboard
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=

# Режим 2 — имена «Участник» / «Claude · AI» и безопасные токены (без публичного ключа на клиенте)
# LIVEBLOCKS_SECRET_KEY=

# Google Gemini (агент на холсте): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Альтернативное имя переменной (если уже используете):
# GOOGLE_API_KEY=
# Необязательно, по умолчанию gemini-2.0-flash
# GEMINI_MODEL=

# Интервал опроса агента (мс), минимум 30000 — иначе частые 429 на бесплатном Gemini
# NEXT_PUBLIC_AGENT_INTERVAL_MS=60000

# Скрытый iframe /peer (синтетический курсор в комнате). На production по умолчанию ВЫКЛ —
# иначе поток presence в Liveblocks может «убить» tldraw. Включить: NEXT_PUBLIC_AI_PEER_IFRAME=1
# NEXT_PUBLIC_AI_PEER_IFRAME=1
